{
  "expo": {
    "name": "JMV Mobile",
    "slug": "jmv-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#004B2D"
    },
    "ios": {
      "bundleIdentifier": "com.jmv.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "JMV Mobile uses your location to show nearby delivery context."
      }
    },
    "android": {
      "package": "com.jmv.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#004B2D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#004B2D"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow JMV Mobile to use your location to show nearby delivery context."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0f54d90e-f3da-4ad4-8c6d-870de50d044a"
      }
    }
  }
}